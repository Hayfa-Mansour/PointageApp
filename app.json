{
  "expo": {
    "name": "Frontend",
    "slug": "Frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "newArchEnabled": true,
      "permissions": ["ACCESS_FINE_LOCATION"]
    },
    "ios": {
      "newArchEnabled": true
    },
    "web": {
      "newArchEnabled": true
     
    }
  }
}
